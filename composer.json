{
    "name": "kommandhub/flutterwave-v3-sw",
    "description": "Integrates the Flutterwave payment gateway into Shopware 6.",
    "type": "shopware-platform-plugin",
    "version": "1.0.0",
    "license": "MIT",
    "keywords": [
        "shopware",
        "shopware6",
        "plugin",
        "payment",
        "flutterwave",
        "gateway",
        "e-commerce",
        "africa",
        "kommandhub"
    ],
    "autoload": {
        "psr-4": {
            "Kommandhub\\FlutterwaveV3SW\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Anitche Chisom",
            "email": "admin@kommandhub.com",
            "role": "Developer"
        }
    ],
    "require": {
        "shopware/core": "~6.6.0 || ~6.7.0",
        "kommandhub/flutterwave-v3": "^1.0"
    },
    "extra": {
        "shopware-plugin-class": "Kommandhub\\FlutterwaveV3SW\\KommandhubFlutterwaveV3SW",
        "label": {
            "de-DE": "Flutterwave für Shopware",
            "en-GB": "Flutterwave for Shopware",
            "fr-FR": "Flutterwave pour Shopware"
        },
        "description": {
            "de-DE": "Integriert das Flutterwave-Zahlungs-Gateway in Shopware 6.",
            "en-GB": "Integrates the Flutterwave payment gateway into Shopware 6.",
            "fr-FR": "Intègre la passerelle de paiement Flutterwave dans Shopware 6."
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true,
            "php-http/discovery": true
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "shopware/dev-tools": "^1.5",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "rregeer/phpunit-coverage-check": "^0.3.1"
    }
}
